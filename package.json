{
  "name": "correctr",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "server": "bun run --cwd packages/server dev",
    "extension:build": "bun run --cwd packages/extension build",
    "extension:dev": "bun run --cwd packages/extension dev",
    "check": "bunx --bun biome check .",
    "format": "bunx --bun biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "@biomejs/cli-darwin-arm64": "^2.4.5",
    "@biomejs/cli-darwin-x64": "^2.4.5",
    "typescript": "^5.9.3"
  }
}
